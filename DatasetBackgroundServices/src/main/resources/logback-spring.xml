<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Properties for log directory and names if needed -->
    <property name="LOG_FILE" value="${LOG_FILE:-${LOG_PATH:-${java.io.tmpdir:-/tmp}}/background.log}"/>

    <!-- Local Development: Console Appender (Pretty-printed) -->
    <springProfile name="default | local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Production/Cloud Run: Standard Out (JSON is better for stackdriver, but we'll stick to a clean pattern for now) -->
    <springProfile name="production | google">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Specific package log levels -->
    <logger name="info.esblurock.background" level="DEBUG"/>
    <logger name="esblurock.info.neo4j" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.hibernate" level="WARN"/>
    
    <!-- Catch and log everything to the root console at INFO -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
